            </div>
            <!--portfolio-->
            <div id="portfolio">
                <h2 class="heading">Portfolio</h2>
                <div class="line"></div>

                <div class="project-container">
                    <div class="project">
                        <a href="https://rahulsingh7985.github.io/Spotify-clone/" target="_blank"><img src="./image.png" alt=""></a>
